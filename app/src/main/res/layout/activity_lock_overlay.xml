<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DD000000"
    android:fitsSystemWindows="true">

    <!-- Glassmorphic Container Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_caller_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#33FFFFFF"
        app:cardBackgroundColor="#22FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Caller App Indicator -->
            <ImageView
                android:id="@+id/iv_overlay_app_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:src="@android:drawable/sym_def_app_icon" />

            <!-- Caller App Name -->
            <TextView
                android:id="@+id/tv_overlay_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WhatsApp"
                android:textSize="14sp"
                android:textColor="#88FFFFFF"
                android:layout_marginBottom="12dp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <!-- Caller Name -->
            <TextView
                android:id="@+id/tv_overlay_caller_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming Call"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <!-- Call Type Indicator -->
            <TextView
                android:id="@+id/tv_overlay_call_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Incoming Voice Call"
                android:textSize="14sp"
                android:textColor="#B3FFFFFF"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <!-- Ripple Pulse Container (Fingerprint/Lock Icon) -->
            <FrameLayout
                android:id="@+id/layout_ripple"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <!-- Inner pulsating circle -->
                <View
                    android:id="@+id/view_pulse_circle"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@android:drawable/presence_invisible" /> <!-- Animated dynamically in code -->

                <!-- Lock Icon -->
                <ImageView
                    android:id="@+id/iv_lock_status"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_secure"
                    app:tint="@android:color/white" />
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Unlock Action Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unlock"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="Unlock to Answer"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_lock_lock"
            app:iconTint="@android:color/white"
            app:backgroundTint="?attr/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Secure unlock required to answer this call"
            android:textSize="12sp"
            android:textColor="#88FFFFFF" />
    </LinearLayout>

</RelativeLayout>
